# production, development
NODE_ENV=production

# Prisma
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/forsenwiki

AUTH_SECRET=
AUTH_TRUST_HOST="true"

DOMAIN=forsen.wiki
# Keep this as-is for production environment.
FULL_DOMAIN=${DOMAIN}
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_ACCESS_LOG=/var/log/access-forsen-wiki.log
CADDY_ACCESS_LOG_JSON=/var/log/access-forsen-wiki.caddylog

ORIGIN=https://${DOMAIN}
VITE_DOMAIN=https://${DOMAIN}
VITE_STATIC_DOMAIN=https://cdn.kappa.wiki

# Used for populating the "Popular articles".
GOATCOUNTER_PREFIX=stats
GOATCOUNTER_API_KEY=
# Set this to true during non-worker-dev
GOATCOUNTER_DISABLED=

# Twitch Auth provider
# https://${DOMAIN}:{CADDY_HTTPS_PORT}/auth/callback/twitch
AUTH_TWITCH_ID=
AUTH_TWITCH_SECRET=

# Harbor Auth provider
# AUTH_HARBOR=


# Cloudflare cache invalidation. Leave these empty when developing.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Cloudflare r2
CLOUDFLARE_R2_ACCOUNT_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET_NAME=

BODY_SIZE_LIMIT=10M