# production, development
NODE_ENV=development

# Prisma
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/forsenwiki

AUTH_SECRET=
AUTH_TRUST_HOST="true"

DOMAIN=localhost
# http:// protocol prefix to make sure caddy doesn't try to use HTTPS for development
FULL_DOMAIN=http://${DOMAIN}
CADDY_HTTP_PORT=3000
CADDY_HTTPS_PORT=5443
CADDY_ACCESS_LOG=/var/log/access-forsen-wiki.log
CADDY_ACCESS_LOG_JSON=/var/log/access-forsen-wiki.caddylog

ORIGIN=http://${DOMAIN}:${CADDY_HTTP_PORT}
VITE_DOMAIN=http://${DOMAIN}:${CADDY_HTTP_PORT}
VITE_STATIC_DOMAIN=http://${DOMAIN}:${CADDY_HTTP_PORT}/usercontent

# Used for populating the "Popular articles".
# Does not work during non-docker-dev.
GOATCOUNTER_PREFIX=http://stats
GOATCOUNTER_API_KEY=
GOATCOUNTER_DISABLED=

# Twitch Auth provider
# http://${DOMAIN}:{CADDY_HTTP_PORT}/auth/callback/twitch
AUTH_TWITCH_ID=
AUTH_TWITCH_SECRET=

# Harbor Auth provider
# AUTH_HARBOR=

# Cloudflare cache invalidation. Leave these empty when developing.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Cloudflare r2
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET_NAME=

BODY_SIZE_LIMIT=10M