{
	"name": "forsenwiki",
	"version": "1.0.0-beta.16",
	"type": "module",
	"scripts": {
		"add-version-file": "node -p \"require('./package.json').version\" > version && git rev-parse --short HEAD >> version",
		"copy-worker-files": "cp -a ./.svelte-kit/output/server/chunks/worker.js ./build/server/chunks/ && cp -a ./.svelte-kit/output/server/chunks/worker2.js ./build/server/chunks/ && cp -a ./.svelte-kit/output/server/chunks/worker3.js ./build/server/chunks/",
		"build": "npm run prisma:generate && npm run add-version-file && svelte-kit sync && npm run build:workers && vite build && npm run copy-worker-files",
		"build:workers": "node buildWorkers.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --ignore \"src/lib/worker/**/worker.js\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"dev": "npm run prisma:generate && svelte-kit sync && npm run build:workers && vite dev",
		"format": "prettier --write .",
		"generate-changelog": "npx conventional-changelog -p conventionalcommits -i CHANGELOG.md -s && node changelogsToHTML.js",
		"generate-tpl": "node generateLicenses.js",
		"lint": "prettier --check . && eslint .",
		"preview": "vite preview",
		"prisma:generate": "prisma generate",
		"prisma:migrate-deploy": "prisma migrate deploy",
		"prisma:migrate-dev": "prisma migrate dev",
		"prisma:seed": "node --experimental-transform-types ./prisma/seed/types.js",
		"start": "node -r dotenv-expand/config build"
	},
	"overrides": {
		"rimraf": {
			"minimatch": {
				"brace-expansion": "^1.1.13"
			}
		},
		"@mapbox/node-pre-gyp": {
			"minimatch": {
				"brace-expansion": "^1.1.13"
			}
		},
		"minimatch": {
			"brace-expansion": "^5.0.5"
		},
		"handlebars": "4.7.9",
		"tar": "7.5.13",
		"cookie": "$cookie",
		"@lexical/clipboard": "$@lexical/clipboard",
		"@lexical/code": "$@lexical/code",
		"@lexical/file": "$@lexical/file",
		"@lexical/hashtag": "$@lexical/hashtag",
		"@lexical/history": "$@lexical/history",
		"@lexical/html": "$@lexical/html",
		"@lexical/link": "$@lexical/link",
		"@lexical/list": "$@lexical/list",
		"@lexical/mark": "$@lexical/mark",
		"@lexical/overflow": "$@lexical/overflow",
		"@lexical/plain-text": "$@lexical/plain-text",
		"@lexical/rich-text": "$@lexical/rich-text",
		"@lexical/selection": "$@lexical/selection",
		"@lexical/table": "$@lexical/table",
		"@lexical/utils": "$@lexical/utils",
		"@lexical/yjs": "$@lexical/yjs",
		"@lexical/markdown": "$@lexical/markdown",
		"@lexical/text": "$@lexical/text",
		"@lexical/extension": "$@lexical/extension",
		"lexical": "$lexical",
		"svelte-lexical@^0.6.4": {
			"@lexical/clipboard": "$@lexical/clipboard",
			"@lexical/code": "$@lexical/code",
			"@lexical/file": "$@lexical/file",
			"@lexical/hashtag": "$@lexical/hashtag",
			"@lexical/history": "$@lexical/history",
			"@lexical/html": "$@lexical/html",
			"@lexical/link": "$@lexical/link",
			"@lexical/list": "$@lexical/list",
			"@lexical/mark": "$@lexical/mark",
			"@lexical/overflow": "$@lexical/overflow",
			"@lexical/plain-text": "$@lexical/plain-text",
			"@lexical/rich-text": "$@lexical/rich-text",
			"@lexical/selection": "$@lexical/selection",
			"@lexical/table": "$@lexical/table",
			"@lexical/utils": "$@lexical/utils",
			"@lexical/yjs": "$@lexical/yjs",
			"@lexical/markdown": "$@lexical/markdown",
			"@lexical/text": "$@lexical/text",
			"@lexical/extension": "$@lexical/extension",
			"lexical": "$lexical",
			"yjs": "$yjs"
		},
		"yjs": "$yjs"
	},
	"dependencies": {
		"@auth/prisma-adapter": "^2.11.2",
		"@auth/sveltekit": "^1.11.2",
		"@aws-sdk/client-s3": "^3.1037.0",
		"@aws-sdk/s3-request-presigner": "^3.1037.0",
		"@fontsource/comic-neue": "^5.2.7",
		"@lexical/clipboard": "0.41.0",
		"@lexical/code": "0.41.0",
		"@lexical/extension": "0.41.0",
		"@lexical/file": "0.41.0",
		"@lexical/hashtag": "0.41.0",
		"@lexical/headless": "0.41.0",
		"@lexical/history": "0.41.0",
		"@lexical/html": "0.41.0",
		"@lexical/link": "0.41.0",
		"@lexical/list": "0.41.0",
		"@lexical/mark": "0.41.0",
		"@lexical/markdown": "0.41.0",
		"@lexical/overflow": "0.41.0",
		"@lexical/plain-text": "0.41.0",
		"@lexical/rich-text": "0.41.0",
		"@lexical/selection": "0.41.0",
		"@lexical/table": "0.41.0",
		"@lexical/text": "0.41.0",
		"@lexical/utils": "0.41.0",
		"@lexical/yjs": "0.41.0",
		"@lucide/svelte": "^1.11.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@tailwindcss/vite": "^4.2.4",
		"cookie": "1.1.1",
		"date-fns": "^4.1.0",
		"diff": "^9.0.0",
		"dotenv": "^17.4.2",
		"dotenv-expand": "^13.0.0",
		"file-type": "^22.0.1",
		"image-size": "^2.0.2",
		"is-url": "^1.2.4",
		"json-diff": "^1.0.6",
		"lexical": "0.41.0",
		"linkedom-global": "^1.0.1",
		"magika": "^1.0.0",
		"pg": "^8.20.0",
		"sanitize-filename": "^1.6.4",
		"svelte-bricks": "^0.4.1",
		"svelte-infinite-loading": "^1.4.0",
		"svelte-lexical": "^0.6.4",
		"sveltekit-sse": "^0.14.3",
		"uint8array-extras": "^1.5.0",
		"y-indexeddb": "^9.0.12",
		"yjs": "13.6.30"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@types/eslint": "^9.6.1",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"conventional-changelog": "^7.2.0",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"esbuild": "^0.28.0",
		"esbuild-svelte": "^0.9.4",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"generate-license-file": "^4.1.1",
		"globals": "^17.5.0",
		"marked": "^18.0.2",
		"marked-gfm-heading-id": "^4.1.4",
		"postcss": "^8.5.10",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"prisma": "^7.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vite": "^7.3.2"
	}
}
